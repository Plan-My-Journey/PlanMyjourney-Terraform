aws_region               = "ap-south-1"
environment              = "prod"
project_name             = "ai-travel"
cluster_name             = "ai-travel-prod"
cluster_version          = "1.29"
vpc_cidr                 = "10.0.0.0/16"
availability_zones       = ["ap-south-1a", "ap-south-1b"]
node_group_min_size      = 2
node_group_desired_size  = 2
node_group_max_size      = 5
node_instance_types      = ["t3.medium"]
node_disk_size           = 50
db_instance_class        = "db.t3.micro"
db_allocated_storage     = 50
db_max_allocated_storage = 100
db_name                  = "ai_travel_prod"
db_username              = "aitravel_admin"
db_backup_retention_days = 30
ecr_repositories         = ["frontend", "ai-service", "travel-service", "user-service", "utility-service"]
acm_certificate_domain   = "api.aitravel.com"
alert_email              = "tkpreethi973@gmail.com"
finops_sender_email      = "tkp4762@gmail.com"
log_retention_days       = 7
github_org               = "your-org"
github_repo              = "ai-travel-planner"
